// ─────────────────────────────────────────────
// Motor de Hierarquia Genérico
// ─────────────────────────────────────────────

model EstruturaHierarquia {
  id            String    @id @default(uuid())
  idOrganizacao String    @map("id_organizacao")
  tabela        String
  nome          String
  mascara       String
  dataInicio    DateTime  @map("data_inicio") @db.Date
  dataFim       DateTime? @map("data_fim") @db.Date
  status        Int       @default(2)
  criadoPor     String    @map("criado_por")
  criadoEm      DateTime  @default(now()) @map("criado_em")
  atualizadoEm  DateTime  @updatedAt @map("atualizado_em")

  organizacao  Organizacao  @relation(fields: [idOrganizacao], references: [id])
  criador      Usuario      @relation(fields: [criadoPor], references: [id])
  categorias   Categoria[]

  @@map("estrutura_hierarquia")
}

model ItemCategoria {
  id          String   @id @default(uuid())
  idItem      String   @map("id_item")
  idCategoria String   @map("id_categoria")
  ativo       Boolean  @default(true)
  criadoEm   DateTime @default(now()) @map("criado_em")

  item      ItemCatalogo @relation(fields: [idItem], references: [id])
  categoria Categoria    @relation(fields: [idCategoria], references: [id])

  @@map("item_categoria")
}

model TipoDocumento {
  id             String   @id @default(uuid())
  idOrganizacao  String   @map("id_organizacao")
  nome           String
  sigla          String
  obrigatorio    Boolean  @default(false)
  ativo          Boolean  @default(true)
  ordem          Int      @default(0)
  criadoEm      DateTime @default(now()) @map("criado_em")
  atualizadoEm  DateTime @updatedAt @map("atualizado_em")

  organizacao Organizacao @relation(fields: [idOrganizacao], references: [id], onDelete: Cascade)

  @@unique([idOrganizacao, sigla])
  @@map("tipo_documento")
}

// ============================================================
// SCHEMA PRISMA — Módulo 2: Análise Inicial (Compras / CPL)
// Adicionar ao schema.prisma existente do projeto dbliciti
// ============================================================

// ── Tabela de motivos de devolução / reprovação ──────────────
model MotivoAnaliseCpl {
  id         Int            @id @default(autoincrement())
  codigo     String         @unique
  descricao  String
  tipo       String         // 'DEVOLUCAO' | 'REPROVACAO' | 'AMBOS'
  ativo      Boolean        @default(true)
  ordem      Int            @default(0)
  analises   AnaliseCpl[]

  @@map("motivo_analise_cpl")
}

// ── Análise CPL principal ─────────────────────────────────────
// Uma análise por ciclo. Cada devolução cria nova versão.
model AnaliseCpl {
  id               String    @id @default(uuid())
  idPedido         String    @map("id_pedido")
  idOrganizacao    String    @map("id_organizacao")
  idAnalista       String?   @map("id_analista")
  versao           Int       @default(1)
  statusAnterior   Int?      @map("status_anterior")
  statusResultado  Int?      @map("status_resultado")
  parecerTecnico   String?   @map("parecer_tecnico")
  idMotivo         Int?      @map("id_motivo")
  motivoTexto      String?   @map("motivo_texto")
  riscosObservados String?   @map("riscos_observados")
  exigeMatrizRisco Boolean   @default(false) @map("exige_matriz_risco")

  // Checklist dos 6 critérios de decisão (JSON flexível)
  // Pendência TERRACAP item 3: implementado como JSON para suportar
  // tanto checklist formal quanto orientação ao analista.
  // Estrutura: { conformidadeDocumental: boolean|null, qualidadeTR: boolean|null,
  //   coerenciaEstimativa: boolean|null, enquadramentoLegal: boolean|null,
  //   viabilidade: boolean|null, adequacaoPCA: boolean|null,
  //   riscoContratacao: 'BAIXO'|'MEDIO'|'ALTO'|null }
  checklist        Json?

  // RVC — Roteiro de Verificação de Conformidade (Anexo IV – Licitação)
  // Array de { item, quesito, rilc, resposta: SIM|NAO|NA|null, numSei, obs }
  rvcLicitacao     Json?     @map("rvc_licitacao")

  slaPrazo         DateTime? @map("sla_prazo")
  dataRecebimento  DateTime? @map("data_recebimento")
  dataConclusao    DateTime? @map("data_conclusao")
  emAtraso         Boolean   @default(false) @map("em_atraso")
  criadoEm        DateTime  @default(now()) @map("criado_em")
  atualizadoEm    DateTime  @updatedAt @map("atualizado_em")

  pedido   Pedido            @relation(fields: [idPedido], references: [id], onDelete: Cascade)
  analista Usuario?          @relation("AnalistaCpl", fields: [idAnalista], references: [id])
  motivo   MotivoAnaliseCpl? @relation(fields: [idMotivo], references: [id])

  @@index([idPedido])
  @@index([idOrganizacao])
  @@index([idAnalista])
  @@map("analise_cpl")
}
// ============================================================
// ADIÇÕES AO schema.prisma — Módulo 3: Definição da Contratação
// Arquivo: backend/prisma/schema.prisma
//
// 1) Adicionar ao model Pedido (dentro do bloco de relations):
//      definicoesContratacao DefinicaoContratacao[]
//
// 2) Adicionar ao model Usuario (dentro do bloco de relations):
//      definicoesResponsavel DefinicaoContratacao[] @relation("DefinicaoResponsavel")
//
// 3) Colar o model abaixo ao final do arquivo, após o model AnaliseCpl
// ============================================================

// ── Definição da Contratação (Módulo 3) ──────────────────────
// Uma definição por ciclo. Ajustes internos geram nova versão.
model DefinicaoContratacao {
  id               String    @id @default(uuid())
  idPedido         String    @map("id_pedido")
  idOrganizacao    String    @map("id_organizacao")
  idResponsavel    String?   @map("id_responsavel")

  versao           Int       @default(1)
  statusAnterior   Int?      @map("status_anterior")
  statusResultado  Int?      @map("status_resultado")

  // Modalidade de contratação
  // PREGAO | CONCORRENCIA | DISPENSA | INEXIGIBILIDADE | DIALOGO_COMPETITIVO | LEILAO
  modalidade              String?
  modalidadeSugerida      String?  @map("modalidade_sugerida")
  modalidadeJustificativa String?  @map("modalidade_justificativa")

  // Critério de julgamento
  // MENOR_PRECO | MAIOR_DESCONTO | TECNICA_PRECO | MELHOR_TECNICA | MAIOR_RETORNO
  criterioJulgamento     String?  @map("criterio_julgamento")
  criterioJustificativa  String?  @map("criterio_justificativa")

  // Estratégia de contratação
  // SRP | LOTE | GLOBAL | ITEM | PARCELAMENTO
  estrategia             String?
  estrategiaJustificativa String? @map("estrategia_justificativa")

  // Forma de execução (restrita a obras/engenharia)
  // PRECO_GLOBAL | PRECO_UNITARIO | TAREFA | INTEGRADA | SEMI_INTEGRADA
  formaExecucao          String?  @map("forma_execucao")

  // Parâmetros do edital (JSON flexível)
  // { habilitacao: { juridica, regularidadeFiscal, qualificacaoTecnica, qualificacaoEconomica },
  //   criteriosTecnicos, qualificacaoEconomica, qualificacaoTecnica }
  parametrosEdital       Json?    @map("parametros_edital")

  // Enquadramento legal (para dispensa / inexigibilidade)
  enquadramentoLegal     String?  @map("enquadramento_legal")
  justificativaLegal     String?  @map("justificativa_legal")

  // Decisão
  parecerTecnico         String?  @map("parecer_tecnico")
  motivoTexto            String?  @map("motivo_texto")
  pendencias             String?

  // Controle SLA
  slaPrazo               DateTime? @map("sla_prazo")
  dataRecebimento        DateTime? @map("data_recebimento")
  dataConclusao          DateTime? @map("data_conclusao")
  emAtraso               Boolean   @default(false) @map("em_atraso")

  criadoEm               DateTime  @default(now()) @map("criado_em")
  atualizadoEm           DateTime  @updatedAt @map("atualizado_em")

  pedido      Pedido   @relation(fields: [idPedido], references: [id], onDelete: Cascade)
  responsavel Usuario? @relation("DefinicaoResponsavel", fields: [idResponsavel], references: [id])

  @@index([idPedido])
  @@index([idOrganizacao])
  @@index([idResponsavel])
  @@map("definicao_contratacao")
}

// ── M3.5 — Elaboração do Edital ──────────────────────────────
model EditalVersao {
  id             String   @id @default(uuid())
  idPedido       String   @map("id_pedido")
  idOrganizacao  String   @map("id_organizacao")
  versao         Int      @default(1)
  nome           String
  tamanho        Int
  mimeType       String   @map("mime_type")
  dados          Bytes
  observacao     String?
  status         String   @default("ELABORACAO")
  idUsuario      String   @map("id_usuario")
  criadoEm      DateTime @default(now()) @map("criado_em")
  atualizadoEm  DateTime @updatedAt @map("atualizado_em")

  pedido      Pedido             @relation(fields: [idPedido], references: [id], onDelete: Cascade)
  usuario     Usuario            @relation("EditalUsuario", fields: [idUsuario], references: [id])
  comentarios EditalComentario[]

  @@index([idPedido])
  @@index([idOrganizacao])
  @@map("edital_versao")
}

model EditalComentario {
  id        String   @id @default(uuid())
  idPedido  String   @map("id_pedido")
  idVersao  String?  @map("id_versao")
  idUsuario String   @map("id_usuario")
  texto     String
  tipo      String   @default("COMENTARIO")
  origem    String   @default("ELABORADOR") @map("origem")
  criadoEm DateTime @default(now()) @map("criado_em")

  pedido   Pedido        @relation(fields: [idPedido], references: [id], onDelete: Cascade)
  versao   EditalVersao? @relation(fields: [idVersao], references: [id], onDelete: SetNull)
  usuario  Usuario       @relation("EditalComentarioUsuario", fields: [idUsuario], references: [id])
  leituras EditalComentarioLeitura[]

  @@index([idPedido])
  @@map("edital_comentario")
}

model EditalComentarioLeitura {
  id           String   @id @default(uuid())
  idComentario String   @map("id_comentario")
  idUsuario    String   @map("id_usuario")
  lidoEm       DateTime @default(now()) @map("lido_em")

  comentario EditalComentario @relation(fields: [idComentario], references: [id], onDelete: Cascade)

  @@unique([idComentario, idUsuario])
  @@index([idUsuario, idComentario])
  @@map("edital_comentario_leitura")
}


// ============================================================
// SCHEMA PRISMA — Módulo PCA (Plano de Contratações Anual)
// Nome interno dbliciti: PAC · Nome oficial Terracap: PCA
// Adicionar ao final de backend/prisma/schema.prisma
//
// Resolve as pendências do handoff_modulo_pca.md:
// 1) Dfd ganha unidadeFornecimento, dataDesejada, idItemVinculado
//    (auto-relação), descricaoObjeto — TODOS incluídos abaixo.
// 2) Aprovação simplificada: SEM alçada fixa em dois níveis no schema.
//    O nível intermediário é liberado via Organizacao.configuracoes
//    (pcaAlcadaIntermediariaHabilitada / pcaAlcadaIntermediariaValor),
//    e o ItemPca só ganha os campos idAprovadorIntermediario /
//    dataAprovacaoIntermediaria para registrar o resultado quando
//    a parametrização da empresa exigir esse passo.
// 3) De-para Sistemas Corporativos ↔ Catálogo (M1): modelo
//    DeParaItemSistemaCorporativo abaixo.
// 4) Os 3 parâmetros (PNCP, corte de risco, alçada) NÃO viram uma
//    tabela nova — reaproveitam o mecanismo já existente de
//    Organizacao.configuracoes (JSON, sem histórico, só estado atual),
//    o mesmo usado hoje em configuracoes.service.ts. Chaves novas:
//    pcaPncpHabilitado, pcaPncpObrigatorio, pcaValorCorteRisco,
//    pcaAlcadaIntermediariaHabilitada, pcaAlcadaIntermediariaValor.
//    (m6PncpHabilitado / m7PncpHabilitado seguem o mesmo padrão
//    quando esses módulos forem parametrizados.)
// 5) Ator de consolidação renomeado para CPLIC em todo o código —
//    ver idConsolidadoPor em ItemPca e comentários abaixo.
// ============================================================

// ── Plano de Contratações Anual (documento-mãe, por exercício) ─
// EM_ELABORACAO(1) → EM_APROVACAO(2) → APROVADO(3) → PUBLICADO(4)
model PlanoContratacaoAnual {
  id            String    @id @default(uuid())
  idOrganizacao String    @map("id_organizacao")
  ano           Int
  versao        Int       @default(1)
  status        Int       @default(1) // 1=EM_ELABORACAO 2=EM_APROVACAO 3=APROVADO 4=PUBLICADO

  idAprovador         String?   @map("id_aprovador")
  dataAprovacao       DateTime? @map("data_aprovacao")
  dataPublicacaoSitio DateTime? @map("data_publicacao_sitio") // divulgação obrigatória no sítio (não desabilitável)

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  organizacao Organizacao @relation(fields: [idOrganizacao], references: [id])
  aprovador   Usuario?    @relation("PlanoPcaAprovador", fields: [idAprovador], references: [id])

  dfds     Dfd[]
  itens      ItemPca[]
  revisoes   RevisaoPca[]
  relatorios RelatorioPca[]
  envios   PncpEnvioPca[]

  @@unique([idOrganizacao, ano, versao])
  @@index([idOrganizacao])
  @@map("plano_contratacao_anual")
}

// ── Demanda do Setor Requisitante (DFD) ─────────────────────
// RASCUNHO(1) → ENVIADO(2) → CONSOLIDADO(3) · ENVIADO → CANCELADO(4)
model Dfd {
  id            String @id @default(uuid())
  idOrganizacao String @map("id_organizacao")
  idPlano       String @map("id_plano")
  idSolicitante String @map("id_solicitante") // usuário do Setor Requisitante que lança a demanda
  idCentroCusto String? @map("id_centro_custo") // unidade (Setor Requisitante)
  numero        String

  // Campos mínimos exigidos pela norma (item 10.1.3.1)
  tipoObjeto               String   @map("tipo_objeto") // BEM | SERVICO | OBRA | TIC
  codigoSistemaCorporativo String   @map("codigo_sistema_corporativo") // código nos Sistemas Corporativos da Terracap
  idItemCatalogo           String?  @map("id_item_catalogo") // de-para resolvido p/ Catálogo M1 (pode ser nulo até resolução)
  unidadeFornecimento       String   @map("unidade_fornecimento")
  quantidade                 Decimal  @db.Decimal(15, 4)
  descricaoObjeto             String   @map("descricao_objeto")
  justificativa               String
  valorEstimado                Decimal  @default(0) @map("valor_estimado") @db.Decimal(15, 2)
  prioridade                    Int      @default(2) // 1=Baixa 2=Media 3=Alta
  dataDesejada                   DateTime @map("data_desejada") @db.Date
  idItemVinculado                 String?  @map("id_item_vinculado") // dependência entre itens (auto-relação)

  status                   Int       @default(1) // 1=RASCUNHO 2=ENVIADO 3=CONSOLIDADO 4=CANCELADO 5=DEVOLVIDO
  foraDaJanela             Boolean   @default(false) @map("fora_da_janela") // inclusão fora de 01/jan-10/fev (item 9.1)
  justificativaForaJanela  String?   @map("justificativa_fora_janela")
  dataEnvio                DateTime? @map("data_envio")
  motivoDevolucao          String?   @map("motivo_devolucao") // preenchido quando a Autoridade Competente devolve o Item PCA

  idItemPca String? @map("id_item_pca") // preenchido na consolidação pela CPLIC

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  organizacao   Organizacao            @relation(fields: [idOrganizacao], references: [id])
  plano         PlanoContratacaoAnual  @relation(fields: [idPlano], references: [id])
  solicitante   Usuario                @relation("DfdSolicitante", fields: [idSolicitante], references: [id])
  centroCusto   CentroCusto?           @relation(fields: [idCentroCusto], references: [id])
  itemCatalogo  ItemCatalogo?          @relation(fields: [idItemCatalogo], references: [id])
  itemVinculado Dfd?                   @relation("DfdVinculado", fields: [idItemVinculado], references: [id])
  dependentes   Dfd[]                  @relation("DfdVinculado")
  itemPca       ItemPca?               @relation(fields: [idItemPca], references: [id])
  sugestoesIa   SugestaoIaDfd[]

  @@unique([idOrganizacao, numero])
  @@index([idOrganizacao])
  @@index([idPlano])
  @@index([status])
  @@index([idItemPca])
  @@map("dfd")
}

// ── Sugestão de IA (preço, duplicidade, agregação) ──────────
// Disparada automaticamente no envio da demanda (RASCUNHO → ENVIADO).
model SugestaoIaDfd {
  id     String @id @default(uuid())
  idDfd  String @map("id_dfd")
  tipo   String // PRECO | DUPLICIDADE | AGREGACAO
  status String @default("PENDENTE") // PENDENTE | ACEITA | REJEITADA

  // tipo = PRECO
  precoSugerido Decimal? @map("preco_sugerido") @db.Decimal(15, 4)
  fontePreco    String?  @map("fonte_preco") // ex.: "Histórico de compras — 12 meses"

  // tipo = DUPLICIDADE | AGREGACAO
  // Array de candidatos: [{ idDfd, numero, descricaoObjeto, scoreSimilaridade }]
  dfdsRelacionadas Json? @map("dfds_relacionadas")

  justificativaIa String? @map("justificativa_ia")

  idDecisorUsuario String?   @map("id_decisor_usuario")
  dataDecisao      DateTime? @map("data_decisao")
  motivoRejeicao   String?   @map("motivo_rejeicao")

  criadoEm DateTime @default(now()) @map("criado_em")

  dfd     Dfd      @relation(fields: [idDfd], references: [id], onDelete: Cascade)
  decisor Usuario? @relation("SugestaoIaDecisor", fields: [idDecisorUsuario], references: [id])

  @@index([idDfd])
  @@index([status])
  @@map("sugestao_ia_dfd")
}

// ── Item PCA consolidado (CPLIC agrega N Dfds de mesma natureza) ─
// EM_ELABORACAO(1) → EM_APROVACAO(2) → APROVADO(3) → PUBLICADO(4) · REJEITADO(5)
model ItemPca {
  id            String @id @default(uuid())
  idOrganizacao String @map("id_organizacao")
  idPlano       String @map("id_plano")
  numero        String

  tipoObjeto          String   @map("tipo_objeto")
  descricaoObjeto      String   @map("descricao_objeto")
  idItemCatalogo        String?  @map("id_item_catalogo")
  unidadeFornecimento    String   @map("unidade_fornecimento")
  quantidadeTotal         Decimal  @default(0) @map("quantidade_total") @db.Decimal(15, 4) // soma das demandas agrupadas
  valorTotal               Decimal  @default(0) @map("valor_total") @db.Decimal(15, 2)       // soma das demandas agrupadas
  prioridade                 Int      @default(2) // maior prioridade entre as demandas de origem
  dataDesejada                 DateTime? @map("data_desejada") @db.Date // menor data desejada entre as origens
  idItemPcaDependencia           String?  @map("id_item_pca_dependencia") // auto-relação p/ calendário de licitação

  status Int @default(1) // 1=EM_ELABORACAO 2=EM_APROVACAO 3=APROVADO 4=PUBLICADO 5=REJEITADO

  // Consolidação — CPLIC (segregação de funções: quem elabora ≠ quem consolida ≠ quem aprova)
  idConsolidadoPor String?   @map("id_consolidado_por")
  dataConsolidacao DateTime? @map("data_consolidacao")

  // Gestão de riscos (obrigatória acima do corte parametrizado por empresa — ver Organizacao.configuracoes)
  exigeGestaoRisco Boolean @default(false) @map("exige_gestao_risco")

  // Aprovação — Autoridade Competente (nível único formal da norma, até 01/03)
  idAprovador      String?   @map("id_aprovador")
  dataAprovacao    DateTime? @map("data_aprovacao")
  parecerAprovacao String?   @map("parecer_aprovacao")
  motivoRejeicao   String?   @map("motivo_rejeicao")

  // Alçada intermediária — só é exigida se a empresa habilitar em Organizacao.configuracoes
  // (pcaAlcadaIntermediariaHabilitada / pcaAlcadaIntermediariaValor)
  idAprovadorIntermediario   String?   @map("id_aprovador_intermediario")
  dataAprovacaoIntermediaria DateTime? @map("data_aprovacao_intermediaria")

  // Calendário de licitação (montado pela CPLIC a partir da data desejada + dependências)
  dataPrevistaLicitacao DateTime? @map("data_prevista_licitacao") @db.Date

  // Execução (Tela 9 / item 9.7 da norma) — declaração MANUAL de quem
  // acompanha o PCA (GECOP), não vem de nenhuma integração automática.
  situacaoExecucao          String?   @map("situacao_execucao") // NO_PRAZO | ATRASADO | EXECUTADO
  dataAtualizacaoExecucao   DateTime? @map("data_atualizacao_execucao")
  atualizadoExecucaoPor     String?   @map("atualizado_execucao_por")

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  organizacao            Organizacao @relation(fields: [idOrganizacao], references: [id])
  plano                  PlanoContratacaoAnual @relation(fields: [idPlano], references: [id])
  itemCatalogo           ItemCatalogo? @relation(fields: [idItemCatalogo], references: [id])
  consolidadoPor         Usuario? @relation("ItemPcaConsolidador", fields: [idConsolidadoPor], references: [id])
  aprovador              Usuario? @relation("ItemPcaAprovador", fields: [idAprovador], references: [id])
  aprovadorIntermediario Usuario? @relation("ItemPcaAprovadorIntermediario", fields: [idAprovadorIntermediario], references: [id])
  dependencia            ItemPca? @relation("ItemPcaDependencia", fields: [idItemPcaDependencia], references: [id])
  dependentes            ItemPca[] @relation("ItemPcaDependencia")
  atualizadoExecucaoPorUsuario Usuario? @relation("ItemPcaExecucao", fields: [atualizadoExecucaoPor], references: [id])

  dfdsOrigem Dfd[]
  riscos     RiscoItemPca[]
  enviosPncp PncpEnvioPca[]
  pedidos    Pedido[]
  revisoes   RevisaoPca[]

  @@unique([idOrganizacao, numero])
  @@index([idPlano])
  @@index([status])
  @@map("item_pca")
}

// ── Gestão de riscos (N hipóteses por Item PCA — diretriz 8.1.10) ─
model RiscoItemPca {
  id               String  @id @default(uuid())
  idItemPca        String  @map("id_item_pca")
  hipotese         String
  probabilidade    Int     @default(2) // 1=Baixa 2=Media 3=Alta
  impacto          Int     @default(2) // 1=Baixo 2=Medio 3=Alto
  medidaPreventiva String  @map("medida_preventiva")
  medidaMitigadora String  @map("medida_mitigadora")
  idResponsavel    String? @map("id_responsavel") // Gestor de Riscos

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  itemPca     ItemPca  @relation(fields: [idItemPca], references: [id], onDelete: Cascade)
  responsavel Usuario? @relation("RiscoResponsavel", fields: [idResponsavel], references: [id])

  @@index([idItemPca])
  @@map("risco_item_pca")
}

// ── De-para: código nos Sistemas Corporativos ↔ Catálogo (M1) ──
// Pendência confirmada na seção 9.1 da especificação funcional.
model DeParaItemSistemaCorporativo {
  id                        String  @id @default(uuid())
  idOrganizacao             String  @map("id_organizacao")
  codigoSistemaCorporativo  String  @map("codigo_sistema_corporativo")
  idItemCatalogo            String  @map("id_item_catalogo")
  ativo                     Boolean @default(true)

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  organizacao  Organizacao  @relation(fields: [idOrganizacao], references: [id])
  itemCatalogo ItemCatalogo @relation(fields: [idItemCatalogo], references: [id])

  @@unique([idOrganizacao, codigoSistemaCorporativo])
  @@map("de_para_item_sistema_corporativo")
}

// ── Fila de envio ao PNCP (assíncrona, com conferência manual) ──
// Publicação PNCP é independente da divulgação no sítio — falha aqui
// não bloqueia nenhuma das duas (seção 9.9 da especificação).
model PncpEnvioPca {
  id            String  @id @default(uuid())
  idOrganizacao String  @map("id_organizacao")
  idItemPca     String? @map("id_item_pca")
  idPlano       String? @map("id_plano")
  tipoEnvio     String  @map("tipo_envio") // PLANO | ITEM | REVISAO
  status        String  @default("PENDENTE") // PENDENTE | EM_CONFERENCIA | ENVIADO | ERRO

  payload      Json?
  respostaPncp Json?   @map("resposta_pncp")
  mensagemErro String? @map("mensagem_erro")
  tentativas   Int     @default(0)

  idConferidoPor  String?   @map("id_conferido_por")
  dataConferencia DateTime? @map("data_conferencia")
  dataEnvio       DateTime? @map("data_envio")

  csvGeradoEm  DateTime? @map("csv_gerado_em")
  csvGeradoPor String?   @map("csv_gerado_por")

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  organizacao  Organizacao            @relation(fields: [idOrganizacao], references: [id])
  itemPca      ItemPca?               @relation(fields: [idItemPca], references: [id])
  plano        PlanoContratacaoAnual? @relation(fields: [idPlano], references: [id])
  conferidoPor Usuario?               @relation("PncpConferidor", fields: [idConferidoPor], references: [id])
  csvGeradoPorUsuario Usuario?        @relation("PncpCsvGerador", fields: [csvGeradoPor], references: [id])

  @@index([idOrganizacao])
  @@index([status])
  @@map("pncp_envio_pca")
}

// ── Revisão / redimensionamento / atualização (janelas da norma) ─
// Também serve de histórico de versões do PCA (tela "Histórico do PCA").
model RevisaoPca {
  id            String @id @default(uuid())
  idPlano       String @map("id_plano") // plano vigente no momento da proposta (versão sendo revisada)
  idOrganizacao String @map("id_organizacao")

  // Item alvo da alteração — vazio em INCLUSAO de item novo (usa
  // descricaoNovoItem/novoValor em vez de referenciar um ItemPca existente)
  idItemPca      String? @map("id_item_pca")
  tipoAlteracao  String  @map("tipo_alteracao") // INCLUSAO | EXCLUSAO | REDIMENSIONAMENTO

  tipoJanela          String  @map("tipo_janela") // SET_NOV | POS_LDO | EXECUCAO
  motivo              String  // fato ensejador (redimensionar/excluir) ou imprevisibilidade (incluir)
  descricaoAlteracoes String  @map("descricao_alteracoes") // resumo legível, gerado ao criar a proposta
  descricaoNovoItem   String? @map("descricao_novo_item")  // só para INCLUSAO
  valorAnterior       Decimal? @map("valor_anterior") @db.Decimal(15, 2)
  novoValor           Decimal? @map("novo_valor") @db.Decimal(15, 2)

  status String @default("EM_APROVACAO") @map("status") // EM_APROVACAO | APROVADO | REJEITADO

  foraDaJanela            Boolean @default(false) @map("fora_da_janela")
  justificativaForaJanela String? @map("justificativa_fora_janela")

  versaoResultante    Int?      @map("versao_resultante") // só preenchido quando aprovado (nova versão criada)

  idSolicitante       String?   @map("id_solicitante")
  idAprovador         String?   @map("id_aprovador")
  dataAprovacao       DateTime? @map("data_aprovacao")
  dataPublicacaoSitio DateTime? @map("data_publicacao_sitio")

  criadoEm DateTime @default(now()) @map("criado_em")

  plano       PlanoContratacaoAnual @relation(fields: [idPlano], references: [id])
  organizacao Organizacao           @relation(fields: [idOrganizacao], references: [id])
  item        ItemPca?              @relation(fields: [idItemPca], references: [id])
  solicitante Usuario?              @relation("RevisaoPcaSolicitante", fields: [idSolicitante], references: [id])
  aprovador   Usuario?              @relation("RevisaoPcaAprovador", fields: [idAprovador], references: [id])

  @@index([idPlano])
  @@index([status])
  @@map("revisao_pca")
}

// ── Histórico de relatórios/publicações do PCA (Tela 9 / item 9.9 da norma) ─
// Um registro por geração: relatório trimestral (interno, GECOP -> Autoridade
// Competente) ou relatório simplificado (público, divulgado no sítio em até
// 15 dias corridos após a aprovação). Os números (itens/valor executados)
// ficam congelados no momento da geração — servem de retrato histórico,
// mesmo que a situação de execução dos itens mude depois.
model RelatorioPca {
  id            String @id @default(uuid())
  idOrganizacao String @map("id_organizacao")
  idPlano       String @map("id_plano")

  tipo      String @map("tipo")      // TRIMESTRAL | SIMPLIFICADO
  trimestre Int?   @map("trimestre") // só para TRIMESTRAL (1-4)

  itensExecutados Int     @default(0) @map("itens_executados")
  itensTotal      Int     @default(0) @map("itens_total")
  valorExecutado  Decimal @default(0) @map("valor_executado") @db.Decimal(15, 2)
  valorTotal      Decimal @default(0) @map("valor_total") @db.Decimal(15, 2)

  idGeradoPor String   @map("id_gerado_por")
  criadoEm    DateTime @default(now()) @map("criado_em")

  organizacao Organizacao            @relation(fields: [idOrganizacao], references: [id])
  plano       PlanoContratacaoAnual  @relation(fields: [idPlano], references: [id])
  geradoPor   Usuario                @relation(fields: [idGeradoPor], references: [id])

  @@index([idOrganizacao])
  @@index([idPlano])
  @@map("relatorio_pca")
}


// ── Integração com ERP externo (Benner, Sankhya, ...) — parametrização por empresa ─
// Alimenta a sincronização diária que replica os itens do ERP do cliente
// para dentro do nosso Catálogo (ItemCatalogo), fonte única usada tanto
// pelas Demandas do PCA quanto pelas Solicitações (M2).
model IntegracaoErp {
  id                String  @id @default(uuid())
  idOrganizacao     String  @unique @map("id_organizacao")

  sistemaErp        String  @map("sistema_erp")       // BENNER | SANKHYA | ...
  tipoAutenticacao  String  @map("tipo_autenticacao")  // USUARIO_SENHA | API_KEY | TOKEN
  urlIntegracao     String  @map("url_integracao")

  usuario                String? // login usado na autenticação (não sigiloso)
  senhaCriptografada     String? @map("senha_criptografada")   // AES-256-GCM — nunca texto puro
  apiKeyCriptografada    String? @map("api_key_criptografada") // AES-256-GCM — nunca texto puro

  ativo                          Boolean   @default(true)
  ultimaSincronizacaoEm          DateTime? @map("ultima_sincronizacao_em")
  ultimoResultado                String?   @map("ultimo_resultado") // SUCESSO | ERRO
  ultimaMensagemErro             String?   @map("ultima_mensagem_erro")
  totalItensUltimaSincronizacao  Int?      @map("total_itens_ultima_sincronizacao")

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  organizacao Organizacao @relation(fields: [idOrganizacao], references: [id])

  @@map("integracao_erp")
}
