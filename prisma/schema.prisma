generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// Tabelas de Domínio
// ─────────────────────────────────────────────

model DominioTabela {
  id        Int      @id @default(autoincrement())
  nome      String   @unique
  descricao String
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now()) @map("criado_em")

  campos DominioField[]
  enums  DominioEnum[]

  @@map("dominio_tabela")
}

model DominioField {
  id          Int      @id @default(autoincrement())
  idTabela    Int      @map("id_tabela")
  nome        String
  descricao   String
  tipo        String
  obrigatorio Boolean  @default(true)
  temEnum     Boolean  @default(false) @map("tem_enum")
  ativo       Boolean  @default(true)
  criadoEm   DateTime @default(now()) @map("criado_em")

  tabela DominioTabela @relation(fields: [idTabela], references: [id])
  enums  DominioEnum[]

  @@unique([idTabela, nome])
  @@map("dominio_campo")
}

model DominioEnum {
  id        Int      @id @default(autoincrement())
  idTabela  Int      @map("id_tabela")
  idCampo   Int      @map("id_campo")
  codigo    Int
  descricao String
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now()) @map("criado_em")

  tabela DominioTabela @relation(fields: [idTabela], references: [id])
  campo  DominioField  @relation(fields: [idCampo], references: [id])

  @@unique([idCampo, codigo])
  @@map("dominio_enum")
}

// ─────────────────────────────────────────────
// Base
// ─────────────────────────────────────────────

// Grupo Empresarial
model Grupo {
  id           String        @id @default(uuid())
  nome         String
  cnpj         String?
  ativo        Boolean       @default(true)
  criadoEm     DateTime      @default(now()) @map("criado_em")

  organizacoes Organizacao[]

  @@map("grupo")
}

model Organizacao {
  id                  String    @id @default(uuid())
  nome                String
  cnpj                String
  modelo              Int       @default(1) // 1=Gestão 2=Compras Centralizadas 3=Híbrido
  ativo               Boolean   @default(true)
  configuracoes       Json?     @map("configuracoes")
  criadoEm            DateTime  @default(now()) @map("criado_em")

  // Dados da Receita Federal
  razaoSocial         String?   @map("razao_social")
  nomeFantasia        String?   @map("nome_fantasia")
  situacaoCadastral   String?   @map("situacao_cadastral")
  naturezaJuridica    String?   @map("natureza_juridica")
  dataAbertura        String?   @map("data_abertura")
  cnaePrincipal       String?   @map("cnae_principal")
  descricaoCnae       String?   @map("descricao_cnae")
  logradouro          String?
  numero              String?
  complemento         String?
  bairro              String?
  municipio           String?
  uf                  String?
  cep                 String?
  telefone            String?
  email               String?
  porte               String?
  capitalSocial       Decimal?  @map("capital_social") @db.Decimal(15, 2)

  // Grupo
  idGrupo             String?   @map("id_grupo")
  slug                String?   @unique

  usuarios              Usuario[]
  usuariosOrganizacao   UsuarioOrganizacao[]
  grupo                 Grupo?                @relation(fields: [idGrupo], references: [id])
  filiais               Filial[]
  centrosCusto          CentroCusto[]
  categorias            Categoria[]
  itens                 ItemCatalogo[]
  alcadas               AlcadaAprovacao[]
  pedidos               Pedido[]
  fornecedores          Fornecedor[]
  cotacoes              Cotacao[]
  contratos             Contrato[]
  licitacoes            Licitacao[]
  alertasSancao         AlertaSancao[]
  logsFracionamento     LogFracionamento[]
  estruturasHierarquia  EstruturaHierarquia[]

  tiposDocumento TipoDocumento[]

  @@map("organizacao")
}

// ─────────────────────────────────────────────
// Filial (entidade separada)
// ─────────────────────────────────────────────

model Filial {
  id                         String    @id @default(uuid())
  nome                       String
  cnpj                       String    @unique
  razaoSocial                String?   @map("razao_social")
  nomeFantasia               String?   @map("nome_fantasia")

  idOrganizacao              String    @map("id_organizacao")
  isMatriz                   Boolean   @default(false) @map("is_matriz")
  isCentralCompras           Boolean   @default(false) @map("is_central_compras")
  isVirtual                  Boolean   @default(false) @map("is_virtual")
  configuracaoCentralCompras Json?     @map("configuracao_central_compras")

  // Endereço
  logradouro                 String?
  numero                     String?
  complemento                String?
  bairro                     String?
  municipio                  String?
  uf                         String?
  cep                        String?

  ativo                      Boolean   @default(true)
  criadoEm                   DateTime  @default(now()) @map("criado_em")

  organizacao         Organizacao          @relation(fields: [idOrganizacao], references: [id])
  usuariosOrganizacao UsuarioOrganizacao[]
  usuariosVinculados  UsuarioFilial[]

  @@map("filial")
}

model Usuario {
  id            String   @id @default(uuid())
  idOrganizacao String   @map("id_organizacao")
  nome          String
  email         String   @unique
  senhaHash     String?  @map("senha_hash")
  trocarSenha   Boolean  @default(true) @map("trocar_senha")
  perfil        String
  alcadaValor   Decimal? @map("alcada_valor") @db.Decimal(15, 2)
  idSubstituto  String?  @map("id_substituto")
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now()) @map("criado_em")
  login              String?   @unique @db.VarChar(15)
  resetToken         String?   @map("reset_token")
  resetTokenExpira   DateTime? @map("reset_token_expira")

  organizacao                 Organizacao             @relation(fields: [idOrganizacao], references: [id])
  organizacoes                UsuarioOrganizacao[]
  substituto                  Usuario?                @relation("Substituto", fields: [idSubstituto], references: [id])
  substituidos                Usuario[]               @relation("Substituto")
  itensCriados                ItemCatalogo[]
  precosRegistrados           PrecoReferencia[]
  auditorias                  AuditoriaItem[]
  pedidosSolicitados          Pedido[]                @relation("PedidoSolicitante")
  aprovacoesPedido            AprovacaoPedido[]       @relation("AprovacaoPedido")
  auditoriasPedido            AuditoriaPedido[]
  contratosComoFiscal         Contrato[]              @relation("ContratoFiscal")
  contratosComoCriador        Contrato[]              @relation("ContratoCriador")
  entregasConfirmadas         Entrega[]               @relation("EntregaConfirmador")
  negociacoesIniciadas        Negociacao[]            @relation("NegociacaoIniciador")
  ocorrenciasRegistradas      OcorrenciaContrato[]    @relation("OcorrenciaRegistrador")
  penalidadesAplicadas        PenalidadeContrato[]    @relation("PenalidadeAplicador")
  fracionamentosDetectados    LogFracionamento[]      @relation("FracionamentoSolicitante")
  estruturasCriadas           EstruturaHierarquia[]
  alcadas                     AlcadaUsuario[]         @relation("AlcadaUsuario")
  filiaisVinculadas           UsuarioFilial[]
  documentosPedido            DocumentoPedido[]
  analisesComoAnalista        AnaliseCpl[]      @relation("AnalistaCpl")
  definicoesResponsavel       DefinicaoContratacao[] @relation("DefinicaoResponsavel")

  @@map("usuario")
}

model UsuarioOrganizacao {
  id              String   @id @default(uuid())
  idUsuario       String   @map("id_usuario")
  idOrganizacao   String   @map("id_organizacao")
  idFilial        String?  @map("id_filial")        // null = acesso a toda a organização
  perfil          String
  alcadaValor     Decimal? @map("alcada_valor") @db.Decimal(15, 2)
  ativo           Boolean  @default(true)
  criadoEm        DateTime @default(now()) @map("criado_em")

  usuario      Usuario      @relation(fields: [idUsuario],     references: [id], onDelete: Cascade)
  organizacao  Organizacao  @relation(fields: [idOrganizacao], references: [id], onDelete: Cascade)
  filial       Filial?      @relation(fields: [idFilial],      references: [id], onDelete: SetNull)

  @@unique([idUsuario, idOrganizacao, idFilial])
  @@map("usuario_organizacao")
}

model UsuarioFilial {
  id        String   @id @default(uuid())
  idUsuario String   @map("id_usuario")
  idFilial  String   @map("id_filial")
  criadoEm DateTime @default(now()) @map("criado_em")

  usuario  Usuario @relation(fields: [idUsuario], references: [id], onDelete: Cascade)
  filial   Filial  @relation(fields: [idFilial],  references: [id], onDelete: Cascade)

  @@unique([idUsuario, idFilial])
  @@map("usuario_filial")
}

model CentroCusto {
  id            String  @id @default(uuid())
  idOrganizacao String  @map("id_organizacao")
  codigo        String
  descricao     String
  ativo         Boolean @default(true)

  organizacao Organizacao @relation(fields: [idOrganizacao], references: [id])
  pedidos     Pedido[]

  @@unique([idOrganizacao, codigo])
  @@map("centro_custo")
}

model Categoria {
  id              String   @id @default(uuid())
  idOrganizacao   String   @map("id_organizacao")
  idEstrutura     String?  @map("id_estrutura")
  nome            String
  codigo          String?
  idPai           String?  @map("id_pai")
  nivel           Int      @default(1)
  atributos       Json?
  ativo           Boolean  @default(true)
  ultimoNivel     Boolean  @default(false) @map("ultimo_nivel")
  criadoEm        DateTime @default(now()) @map("criado_em")
  atualizadoEm    DateTime @updatedAt @map("atualizado_em")

  organizacao    Organizacao              @relation(fields: [idOrganizacao], references: [id])
  estrutura      EstruturaHierarquia?     @relation(fields: [idEstrutura], references: [id])
  pai            Categoria?               @relation("CategoriaPai", fields: [idPai], references: [id])
  filhos         Categoria[]              @relation("CategoriaPai")
  itens          ItemCatalogo[]
  qualificacoes  QualificacaoFornecedor[]
  itemCategorias ItemCategoria[]

  @@map("categoria")
}

// ─────────────────────────────────────────────
// M1 — Catálogo
// ─────────────────────────────────────────────

model ItemCatalogo {
  id                 String   @id @default(uuid())
  idOrganizacao      String   @map("id_organizacao")
  codigoInterno      String   @map("codigo_interno")
  nome               String
  descricaoTecnica   String   @map("descricao_tecnica")
  tipo               Int      @default(1)
  unidadeMedida      String   @map("unidade_medida")
  idCategoria        String?  @map("id_categoria")
  codigoCatmatCatser String?  @map("codigo_catmat_catser")
  status             Int      @default(1)
  sigilo             Boolean  @default(false)
  usoUnico           Boolean  @default(false) @map("uso_unico")
  idItemSucessor     String?  @map("id_item_sucessor")
  atributosExtras    Json?    @map("atributos_extras")
  criadoPor          String   @map("criado_por")
  criadoEm           DateTime @default(now()) @map("criado_em")
  atualizadoEm       DateTime @updatedAt @map("atualizado_em")

  organizacao     Organizacao       @relation(fields: [idOrganizacao], references: [id])
  categoria       Categoria?        @relation(fields: [idCategoria], references: [id])
  criador         Usuario           @relation(fields: [criadoPor], references: [id])
  sucessor        ItemCatalogo?     @relation("ItemSucessor", fields: [idItemSucessor], references: [id])
  predecessores   ItemCatalogo[]    @relation("ItemSucessor")
  precos          PrecoReferencia[]
  auditorias      AuditoriaItem[]
  itensPedido     ItemPedido[]
  itensCotacao    ItemCotacao[]
  itensContrato   ItemContrato[]
  itemCategorias  ItemCategoria[]

  @@unique([idOrganizacao, codigoInterno])
  @@map("item_catalogo")
}

model PrecoReferencia {
  id             String   @id @default(uuid())
  idItem         String   @map("id_item")
  valor          Decimal  @db.Decimal(15, 4)
  fonte          String
  dataReferencia DateTime @map("data_referencia") @db.Date
  responsavelId  String   @map("responsavel_id")
  criadoEm      DateTime @default(now()) @map("criado_em")

  item        ItemCatalogo @relation(fields: [idItem], references: [id])
  responsavel Usuario      @relation(fields: [responsavelId], references: [id])

  @@map("preco_referencia")
}

model AuditoriaItem {
  id          String   @id @default(uuid())
  idItem      String   @map("id_item")
  acao        String
  campo       String?
  valorAntes  String?  @map("valor_antes")
  valorDepois String?  @map("valor_depois")
  usuarioId   String   @map("usuario_id")
  criadoEm   DateTime @default(now()) @map("criado_em")

  item    ItemCatalogo @relation(fields: [idItem], references: [id])
  usuario Usuario      @relation(fields: [usuarioId], references: [id])

  @@map("auditoria_item")
}

// ─────────────────────────────────────────────
// M2 — Pedido de Compra
// ─────────────────────────────────────────────

model AlcadaAprovacao {
  id                String    @id @default(uuid())
  idOrganizacao     String    @map("id_organizacao")
  nome              String
  tipo              Int       @default(1) // 1=Pedido Compra 2=Cotacao 3=Contrato 4=Licitacao
  urgente           Boolean   @default(false)
  criticidadePadrao Int       @default(1) @map("criticidade_padrao") // 1=Normal 2=Alta 3=Maxima
  alcada            Boolean   @default(false)
  dataInicio        DateTime? @map("data_inicio")
  dataFim           DateTime? @map("data_fim")
  ativo             Boolean   @default(true)
  criadoEm          DateTime  @default(now()) @map("criado_em")
  atualizadoEm      DateTime  @updatedAt @map("atualizado_em")

  organizacao Organizacao       @relation(fields: [idOrganizacao], references: [id])
  usuarios    AlcadaUsuario[]
  aprovacoes  AprovacaoPedido[]
  pedidos     Pedido[]

  @@map("alcada_aprovacao")
}

model AlcadaUsuario {
  id       String   @id @default(uuid())
  idAlcada String   @map("id_alcada")
  idUsuario String  @map("id_usuario")
  status   Int      @default(1) // 1=Ativo 2=Bloqueado
  criadoEm DateTime @default(now()) @map("criado_em")

  alcada  AlcadaAprovacao @relation(fields: [idAlcada], references: [id])
  usuario Usuario         @relation("AlcadaUsuario", fields: [idUsuario], references: [id])

  @@map("alcada_usuario")
}

model Pedido {
  id            String   @id @default(uuid())
  idOrganizacao String   @map("id_organizacao")
  numero        String
  idSolicitante String   @map("id_solicitante")
  idCentroCusto String?  @map("id_centro_custo")
  idAlcada      String?  @map("id_alcada")
  criticidade   Int      @default(1) // 1=Normal 2=Alta 3=Maxima
  justificativa String
  valorTotal    Decimal  @default(0) @map("valor_total") @db.Decimal(15, 2)
  status        Int      @default(1)
  nivelAtual    Int      @default(0) @map("nivel_atual")
  destinoPos    Int?     @map("destino_pos")
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  organizacao Organizacao       @relation(fields: [idOrganizacao], references: [id])
  solicitante Usuario           @relation("PedidoSolicitante", fields: [idSolicitante], references: [id])
  centroCusto CentroCusto?      @relation(fields: [idCentroCusto], references: [id])
  alcada      AlcadaAprovacao?  @relation(fields: [idAlcada], references: [id])
  itens       ItemPedido[]
  aprovacoes  AprovacaoPedido[]
  auditorias  AuditoriaPedido[]
  cotacoes    Cotacao[]
  documentos  DocumentoPedido[]
  analisesCpl AnaliseCpl[]
  definicoesContratacao DefinicaoContratacao[]

  @@unique([idOrganizacao, numero])
  @@map("pedido")
}

model ItemPedido {
  id            String  @id @default(uuid())
  idPedido      String  @map("id_pedido")
  idItem        String  @map("id_item")
  quantidade    Decimal @db.Decimal(15, 4)
  precoUnitario Decimal @map("preco_unitario") @db.Decimal(15, 4)
  subtotal      Decimal @db.Decimal(15, 2)
  observacao    String?

  pedido Pedido       @relation(fields: [idPedido], references: [id])
  item   ItemCatalogo @relation(fields: [idItem], references: [id])

  @@map("item_pedido")
}

model AprovacaoPedido {
  id            String   @id @default(uuid())
  idPedido      String   @map("id_pedido")
  idAlcada      String   @map("id_alcada")
  idAprovador   String   @map("id_aprovador")
  nivel         Int
  decisao       Int
  justificativa String?
  criadoEm     DateTime @default(now()) @map("criado_em")

  pedido    Pedido           @relation(fields: [idPedido], references: [id])
  alcada    AlcadaAprovacao? @relation(fields: [idAlcada], references: [id])
  aprovador Usuario          @relation("AprovacaoPedido", fields: [idAprovador], references: [id])

  @@map("aprovacao_pedido")
}

model AuditoriaPedido {
  id          String   @id @default(uuid())
  idPedido    String   @map("id_pedido")
  acao        String
  campo       String?
  valorAntes  String?  @map("valor_antes")
  valorDepois String?  @map("valor_depois")
  usuarioId   String   @map("usuario_id")
  criadoEm   DateTime @default(now()) @map("criado_em")

  pedido  Pedido  @relation(fields: [idPedido], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("auditoria_pedido")
}

model DocumentoPedido {
  id          String   @id @default(uuid())
  idPedido    String   @map("id_pedido")
  tipo        String   // DFD | ETP | TR | PESQUISA_PRECO | COMPLEMENTAR
  nome        String
  tamanho     Int
  mimeType    String   @map("mime_type")
  dados       Bytes
  idUsuario   String   @map("id_usuario")
  criadoEm   DateTime @default(now()) @map("criado_em")

  pedido  Pedido  @relation(fields: [idPedido], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [idUsuario], references: [id])

  @@map("documento_pedido")
}


// ─────────────────────────────────────────────
// M5 — Fornecedores
// ─────────────────────────────────────────────

model Fornecedor {
  id             String   @id @default(uuid())
  idOrganizacao  String   @map("id_organizacao")
  cnpj           String
  razaoSocial    String   @map("razao_social")
  nomeFantasia   String?  @map("nome_fantasia")
  email          String?
  telefone       String?
  telefone2      String?
  status         Int      @default(1)
  motivoBloqueio String?  @map("motivo_bloqueio")

  // Dados da Receita Federal
  situacaoCadastral   Int?     @map("situacao_cadastral")
  descricaoSituacao   String?  @map("descricao_situacao")
  dataSituacao        String?  @map("data_situacao")
  dataInicioAtividade String?  @map("data_inicio_atividade")
  naturezaJuridica    String?  @map("natureza_juridica")
  porte               String?
  capitalSocial       Decimal? @map("capital_social")
  cnaeAtividade       String?  @map("cnae_atividade")
  cnaeDescricao       String?  @map("cnae_descricao")

  // Endereço
  logradouro     String?
  numeroEndereco String?  @map("numero_endereco")
  complemento    String?
  bairro         String?
  municipio      String?
  uf             String?
  cep            String?

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  organizacao   Organizacao              @relation(fields: [idOrganizacao], references: [id])
  qualificacoes QualificacaoFornecedor[]
  documentos    DocumentoFornecedor[]
  convites      ConviteCotacao[]
  contratos     Contrato[]
  alertasSancao AlertaSancao[]

  @@unique([idOrganizacao, cnpj])
  @@map("fornecedor")
}

model QualificacaoFornecedor {
  id            String  @id @default(uuid())
  idFornecedor  String  @map("id_fornecedor")
  idCategoria   String  @map("id_categoria")
  capacidade    String?
  certificacoes String?
  ativo         Boolean @default(true)

  fornecedor Fornecedor @relation(fields: [idFornecedor], references: [id])
  categoria  Categoria  @relation(fields: [idCategoria], references: [id])

  @@unique([idFornecedor, idCategoria])
  @@map("qualificacao_fornecedor")
}

model DocumentoFornecedor {
  id             String    @id @default(uuid())
  idFornecedor   String    @map("id_fornecedor")
  tipo           String
  numero         String?
  dataEmissao    DateTime? @map("data_emissao") @db.Date
  dataVencimento DateTime? @map("data_vencimento") @db.Date
  arquivo        String?
  status         Int       @default(1)
  criadoEm      DateTime  @default(now()) @map("criado_em")

  fornecedor Fornecedor @relation(fields: [idFornecedor], references: [id])

  @@map("documento_fornecedor")
}

// ─────────────────────────────────────────────
// M3 — Cotação & Portal Externo
// ─────────────────────────────────────────────

model Cotacao {
  id            String   @id @default(uuid())
  idOrganizacao String   @map("id_organizacao")
  idPedido      String?  @map("id_pedido")
  numero        String
  titulo        String
  modalidade    String
  prazoRespostas DateTime @map("prazo_respostas")
  sigilo        Boolean  @default(true)
  status        Int      @default(1)
  criadoPor     String   @map("criado_por")
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  organizacao Organizacao      @relation(fields: [idOrganizacao], references: [id])
  pedido      Pedido?          @relation(fields: [idPedido], references: [id])
  itens       ItemCotacao[]
  convites    ConviteCotacao[]

  @@unique([idOrganizacao, numero])
  @@map("cotacao")
}

model ItemCotacao {
  id         String  @id @default(uuid())
  idCotacao  String  @map("id_cotacao")
  idItem     String  @map("id_item")
  quantidade Decimal @db.Decimal(15, 4)
  unidade    String

  cotacao   Cotacao      @relation(fields: [idCotacao], references: [id])
  item      ItemCatalogo @relation(fields: [idItem], references: [id])
  propostas Proposta[]

  @@map("item_cotacao")
}

model ConviteCotacao {
  id           String    @id @default(uuid())
  idCotacao    String    @map("id_cotacao")
  idFornecedor String    @map("id_fornecedor")
  token        String    @unique @default(uuid())
  status       Int       @default(1)
  enviadoEm    DateTime? @map("enviado_em")
  respondidoEm DateTime? @map("respondido_em")

  cotacao    Cotacao    @relation(fields: [idCotacao], references: [id])
  fornecedor Fornecedor @relation(fields: [idFornecedor], references: [id])
  propostas  Proposta[]

  @@unique([idCotacao, idFornecedor])
  @@map("convite_cotacao")
}

model Proposta {
  id            String   @id @default(uuid())
  idConvite     String   @map("id_convite")
  idItemCotacao String   @map("id_item_cotacao")
  precoUnitario Decimal  @map("preco_unitario") @db.Decimal(15, 4)
  subtotal      Decimal  @db.Decimal(15, 2)
  observacao    String?
  comprovante   String?
  homologada    Boolean  @default(false)
  criadoEm    DateTime   @default(now()) @map("criado_em")

  convite     ConviteCotacao @relation(fields: [idConvite], references: [id])
  itemCotacao ItemCotacao    @relation(fields: [idItemCotacao], references: [id])

  @@map("proposta")
}

// ─────────────────────────────────────────────
// M6 — Contratos
// ─────────────────────────────────────────────

model Contrato {
  id                  String    @id @default(uuid())
  idOrganizacao       String    @map("id_organizacao")
  idCotacao           String    @unique @map("id_cotacao")
  numero              String
  titulo              String
  valorTotal          Decimal   @map("valor_total") @db.Decimal(15, 2)
  dataInicio          DateTime  @map("data_inicio") @db.Date
  dataFim             DateTime  @map("data_fim") @db.Date
  idFornecedor        String    @map("id_fornecedor")
  idFiscal            String?   @map("id_fiscal")
  status              Int       @default(1)
  urlDocumento        String?   @map("url_documento")
  assinadoEm          DateTime? @map("assinado_em")
  criadoPor           String    @map("criado_por")
  criadoEm            DateTime  @default(now()) @map("criado_em")
  atualizadoEm        DateTime  @updatedAt @map("atualizado_em")
  dataEncerramento    DateTime? @map("data_encerramento") @db.Date
  motivoEncerramento  String?   @map("motivo_encerramento")
  tipoEncerramento    String?   @map("tipo_encerramento")

  organizacao  Organizacao          @relation(fields: [idOrganizacao], references: [id])
  fornecedor   Fornecedor           @relation(fields: [idFornecedor], references: [id])
  fiscal       Usuario?             @relation("ContratoFiscal", fields: [idFiscal], references: [id])
  criador      Usuario              @relation("ContratoCriador", fields: [criadoPor], references: [id])
  itens        ItemContrato[]
  entregas     Entrega[]
  negociacoes  Negociacao[]
  licitacoes   Licitacao[]
  ocorrencias  OcorrenciaContrato[]

  @@unique([idOrganizacao, numero])
  @@map("contrato")
}

model ItemContrato {
  id            String  @id @default(uuid())
  idContrato    String  @map("id_contrato")
  idItem        String  @map("id_item")
  quantidade    Decimal @db.Decimal(15, 4)
  precoUnitario Decimal @map("preco_unitario") @db.Decimal(15, 4)
  subtotal      Decimal @db.Decimal(15, 2)
  unidade       String

  contrato Contrato     @relation(fields: [idContrato], references: [id])
  item     ItemCatalogo @relation(fields: [idItem], references: [id])

  @@map("item_contrato")
}

model Entrega {
  id            String    @id @default(uuid())
  idContrato    String    @map("id_contrato")
  numero        Int
  descricao     String
  dataEsperada  DateTime  @map("data_esperada") @db.Date
  dataEfetiva   DateTime? @map("data_efetiva") @db.Date
  status        Int       @default(1)
  observacao    String?
  confirmadoPor String?   @map("confirmado_por")
  criadoEm      DateTime  @default(now()) @map("criado_em")

  contrato  Contrato @relation(fields: [idContrato], references: [id])
  confirma  Usuario? @relation("EntregaConfirmador", fields: [confirmadoPor], references: [id])

  contestadoEm      DateTime? @map("contestado_em")
  motivoContestacao String?   @map("motivo_contestacao")
  statusContestacao String?   @map("status_contestacao")

  @@map("entrega")
}

// ─────────────────────────────────────────────
// M4 — Negociação
// ─────────────────────────────────────────────

model Negociacao {
  id          String   @id @default(uuid())
  idContrato  String   @map("id_contrato")
  iniciadorId String   @map("iniciador_id")
  status      Int      @default(1)
  criadoEm   DateTime @default(now()) @map("criado_em")

  contrato    Contrato             @relation(fields: [idContrato], references: [id])
  iniciador   Usuario              @relation("NegociacaoIniciador", fields: [iniciadorId], references: [id])
  mensagens   MensagemNegociacao[]

  @@map("negociacao")
}

model MensagemNegociacao {
  id           String   @id @default(uuid())
  idNegociacao String   @map("id_negociacao")
  remetente    String
  conteudo     String
  criadoEm   DateTime @default(now()) @map("criado_em")

  negociacao Negociacao @relation(fields: [idNegociacao], references: [id])

  @@map("mensagem_negociacao")
}

// ─────────────────────────────────────────────
// M7 — Licitação
// ─────────────────────────────────────────────

model Licitacao {
  id                  String    @id @default(uuid())
  idOrganizacao       String    @map("id_organizacao")
  idContrato          String    @unique @map("id_contrato")
  numero              String
  modalidade          String
  status              Int       @default(1)
  urlSistemaExterno   String?   @map("url_sistema_externo")
  dataEnvio           DateTime  @default(now()) @map("data_envio")
  dataResultado       DateTime? @map("data_resultado")
  resultado           String?
  observacao          String?
  tentativas          Int       @default(1)
  criadoEm            DateTime  @default(now()) @map("criado_em")
  atualizadoEm        DateTime  @updatedAt @map("atualizado_em")

  organizacao Organizacao     @relation(fields: [idOrganizacao], references: [id])
  contrato    Contrato        @relation(fields: [idContrato], references: [id])
  logs        LogIntegracao[]

  @@unique([idOrganizacao, numero])
  @@map("licitacao")
}

model LogIntegracao {
  id           String   @id @default(uuid())
  idLicitacao  String   @map("id_licitacao")
  tentativa    Int
  status       String
  payload      Json?
  resposta     Json?
  erro         String?
  criadoEm     DateTime @default(now()) @map("criado_em")

  licitacao Licitacao @relation(fields: [idLicitacao], references: [id])

  @@map("log_integracao")
}

// ─────────────────────────────────────────────
// M6 — Ocorrências e Penalidades
// ─────────────────────────────────────────────

model OcorrenciaContrato {
  id             String   @id @default(uuid())
  idContrato     String   @map("id_contrato")
  tipo           String
  descricao      String
  dataOcorrencia DateTime @map("data_ocorrencia") @db.Date
  registradoPor  String   @map("registrado_por")
  status         Int      @default(1)
  criadoEm       DateTime @default(now()) @map("criado_em")
  atualizadoEm   DateTime @updatedAt @map("atualizado_em")

  contrato    Contrato             @relation(fields: [idContrato], references: [id])
  registrador Usuario              @relation("OcorrenciaRegistrador", fields: [registradoPor], references: [id])
  penalidades PenalidadeContrato[]

  @@map("ocorrencia_contrato")
}

model PenalidadeContrato {
  id             String   @id @default(uuid())
  idOcorrencia   String   @map("id_ocorrencia")
  tipo           String
  valor          Decimal? @db.Decimal(15, 2)
  descricao      String
  aplicadoPor    String   @map("aplicado_por")
  dataAplicacao  DateTime @map("data_aplicacao") @db.Date
  criadoEm       DateTime @default(now()) @map("criado_em")

  ocorrencia OcorrenciaContrato @relation(fields: [idOcorrencia], references: [id])
  aplicador  Usuario            @relation("PenalidadeAplicador", fields: [aplicadoPor], references: [id])

  @@map("penalidade_contrato")
}

// ─────────────────────────────────────────────
// MT — Monitoramento & Alertas
// ─────────────────────────────────────────────

model AlertaSancao {
  id            String   @id @default(uuid())
  idOrganizacao String   @map("id_organizacao")
  idFornecedor  String   @map("id_fornecedor")
  tipo          String
  descricao     String
  fonte         String
  dataDeteccao  DateTime @default(now()) @map("data_deteccao")
  status        Int      @default(1)
  criadoEm      DateTime @default(now()) @map("criado_em")

  organizacao Organizacao @relation(fields: [idOrganizacao], references: [id])
  fornecedor  Fornecedor  @relation(fields: [idFornecedor], references: [id])

  @@map("alerta_sancao")
}

model LogFracionamento {
  id                String   @id @default(uuid())
  idOrganizacao     String   @map("id_organizacao")
  idSolicitante     String   @map("id_solicitante")
  valorTotal        Decimal  @map("valor_total") @db.Decimal(15, 2)
  quantidadePedidos Int      @map("quantidade_pedidos")
  pedidosIds        Json     @map("pedidos_ids")
  nivelRisco        Int      @map("nivel_risco")
  descricao         String
  status            Int      @default(1)
  criadoEm          DateTime @default(now()) @map("criado_em")

  organizacao Organizacao @relation(fields: [idOrganizacao], references: [id])
  solicitante Usuario     @relation("FracionamentoSolicitante", fields: [idSolicitante], references: [id])

  @@map("log_fracionamento")
}

// ─────────────────────────────────────────────
// Motor de Hierarquia Genérico
// ─────────────────────────────────────────────

model EstruturaHierarquia {
  id            String    @id @default(uuid())
  idOrganizacao String    @map("id_organizacao")
  tabela        String
  nome          String
  mascara       String
  dataInicio    DateTime  @map("data_inicio") @db.Date
  dataFim       DateTime? @map("data_fim") @db.Date
  status        Int       @default(2)
  criadoPor     String    @map("criado_por")
  criadoEm      DateTime  @default(now()) @map("criado_em")
  atualizadoEm  DateTime  @updatedAt @map("atualizado_em")

  organizacao  Organizacao  @relation(fields: [idOrganizacao], references: [id])
  criador      Usuario      @relation(fields: [criadoPor], references: [id])
  categorias   Categoria[]

  @@map("estrutura_hierarquia")
}

model ItemCategoria {
  id          String   @id @default(uuid())
  idItem      String   @map("id_item")
  idCategoria String   @map("id_categoria")
  ativo       Boolean  @default(true)
  criadoEm   DateTime @default(now()) @map("criado_em")

  item      ItemCatalogo @relation(fields: [idItem], references: [id])
  categoria Categoria    @relation(fields: [idCategoria], references: [id])

  @@map("item_categoria")
}

model TipoDocumento {
  id             String   @id @default(uuid())
  idOrganizacao  String   @map("id_organizacao")
  nome           String
  sigla          String
  obrigatorio    Boolean  @default(false)
  ativo          Boolean  @default(true)
  ordem          Int      @default(0)
  criadoEm      DateTime @default(now()) @map("criado_em")
  atualizadoEm  DateTime @updatedAt @map("atualizado_em")

  organizacao Organizacao @relation(fields: [idOrganizacao], references: [id], onDelete: Cascade)

  @@unique([idOrganizacao, sigla])
  @@map("tipo_documento")
}

// ============================================================
// SCHEMA PRISMA — Módulo 2: Análise Inicial (Compras / CPL)
// Adicionar ao schema.prisma existente do projeto dbliciti
// ============================================================

// ── Tabela de motivos de devolução / reprovação ──────────────
model MotivoAnaliseCpl {
  id         Int            @id @default(autoincrement())
  codigo     String         @unique
  descricao  String
  tipo       String         // 'DEVOLUCAO' | 'REPROVACAO' | 'AMBOS'
  ativo      Boolean        @default(true)
  ordem      Int            @default(0)
  analises   AnaliseCpl[]

  @@map("motivo_analise_cpl")
}

// ── Análise CPL principal ─────────────────────────────────────
// Uma análise por ciclo. Cada devolução cria nova versão.
model AnaliseCpl {
  id               String    @id @default(uuid())
  idPedido         String    @map("id_pedido")
  idOrganizacao    String    @map("id_organizacao")
  idAnalista       String?   @map("id_analista")
  versao           Int       @default(1)
  statusAnterior   Int?      @map("status_anterior")
  statusResultado  Int?      @map("status_resultado")
  parecerTecnico   String?   @map("parecer_tecnico")
  idMotivo         Int?      @map("id_motivo")
  motivoTexto      String?   @map("motivo_texto")
  riscosObservados String?   @map("riscos_observados")
  exigeMatrizRisco Boolean   @default(false) @map("exige_matriz_risco")

  // Checklist dos 6 critérios de decisão (JSON flexível)
  // Pendência TERRACAP item 3: implementado como JSON para suportar
  // tanto checklist formal quanto orientação ao analista.
  // Estrutura: { conformidadeDocumental: boolean|null, qualidadeTR: boolean|null,
  //   coerenciaEstimativa: boolean|null, enquadramentoLegal: boolean|null,
  //   viabilidade: boolean|null, adequacaoPCA: boolean|null,
  //   riscoContratacao: 'BAIXO'|'MEDIO'|'ALTO'|null }
  checklist        Json?

  // RVC — Roteiro de Verificação de Conformidade (Anexo IV – Licitação)
  // Array de { item, quesito, rilc, resposta: SIM|NAO|NA|null, numSei, obs }
  rvcLicitacao     Json?     @map("rvc_licitacao")

  slaPrazo         DateTime? @map("sla_prazo")
  dataRecebimento  DateTime? @map("data_recebimento")
  dataConclusao    DateTime? @map("data_conclusao")
  emAtraso         Boolean   @default(false) @map("em_atraso")
  criadoEm        DateTime  @default(now()) @map("criado_em")
  atualizadoEm    DateTime  @updatedAt @map("atualizado_em")

  pedido   Pedido            @relation(fields: [idPedido], references: [id], onDelete: Cascade)
  analista Usuario?          @relation("AnalistaCpl", fields: [idAnalista], references: [id])
  motivo   MotivoAnaliseCpl? @relation(fields: [idMotivo], references: [id])

  @@index([idPedido])
  @@index([idOrganizacao])
  @@index([idAnalista])
  @@map("analise_cpl")
}
// ============================================================
// ADIÇÕES AO schema.prisma — Módulo 3: Definição da Contratação
// Arquivo: backend/prisma/schema.prisma
//
// 1) Adicionar ao model Pedido (dentro do bloco de relations):
//      definicoesContratacao DefinicaoContratacao[]
//
// 2) Adicionar ao model Usuario (dentro do bloco de relations):
//      definicoesResponsavel DefinicaoContratacao[] @relation("DefinicaoResponsavel")
//
// 3) Colar o model abaixo ao final do arquivo, após o model AnaliseCpl
// ============================================================

// ── Definição da Contratação (Módulo 3) ──────────────────────
// Uma definição por ciclo. Ajustes internos geram nova versão.
model DefinicaoContratacao {
  id               String    @id @default(uuid())
  idPedido         String    @map("id_pedido")
  idOrganizacao    String    @map("id_organizacao")
  idResponsavel    String?   @map("id_responsavel")

  versao           Int       @default(1)
  statusAnterior   Int?      @map("status_anterior")
  statusResultado  Int?      @map("status_resultado")

  // Modalidade de contratação
  // PREGAO | CONCORRENCIA | DISPENSA | INEXIGIBILIDADE | DIALOGO_COMPETITIVO | LEILAO
  modalidade              String?
  modalidadeSugerida      String?  @map("modalidade_sugerida")
  modalidadeJustificativa String?  @map("modalidade_justificativa")

  // Critério de julgamento
  // MENOR_PRECO | MAIOR_DESCONTO | TECNICA_PRECO | MELHOR_TECNICA | MAIOR_RETORNO
  criterioJulgamento     String?  @map("criterio_julgamento")
  criterioJustificativa  String?  @map("criterio_justificativa")

  // Estratégia de contratação
  // SRP | LOTE | GLOBAL | ITEM | PARCELAMENTO
  estrategia             String?
  estrategiaJustificativa String? @map("estrategia_justificativa")

  // Forma de execução (restrita a obras/engenharia)
  // PRECO_GLOBAL | PRECO_UNITARIO | TAREFA | INTEGRADA | SEMI_INTEGRADA
  formaExecucao          String?  @map("forma_execucao")

  // Parâmetros do edital (JSON flexível)
  // { habilitacao: { juridica, regularidadeFiscal, qualificacaoTecnica, qualificacaoEconomica },
  //   criteriosTecnicos, qualificacaoEconomica, qualificacaoTecnica }
  parametrosEdital       Json?    @map("parametros_edital")

  // Enquadramento legal (para dispensa / inexigibilidade)
  enquadramentoLegal     String?  @map("enquadramento_legal")
  justificativaLegal     String?  @map("justificativa_legal")

  // Decisão
  parecerTecnico         String?  @map("parecer_tecnico")
  motivoTexto            String?  @map("motivo_texto")
  pendencias             String?

  // Controle SLA
  slaPrazo               DateTime? @map("sla_prazo")
  dataRecebimento        DateTime? @map("data_recebimento")
  dataConclusao          DateTime? @map("data_conclusao")
  emAtraso               Boolean   @default(false) @map("em_atraso")

  criadoEm               DateTime  @default(now()) @map("criado_em")
  atualizadoEm           DateTime  @updatedAt @map("atualizado_em")

  pedido      Pedido   @relation(fields: [idPedido], references: [id], onDelete: Cascade)
  responsavel Usuario? @relation("DefinicaoResponsavel", fields: [idResponsavel], references: [id])

  @@index([idPedido])
  @@index([idOrganizacao])
  @@index([idResponsavel])
  @@map("definicao_contratacao")
}
